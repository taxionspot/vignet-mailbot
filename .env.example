# VignetteHub mailbot, voorbeeldconfiguratie.
# Kopieer dit bestand naar .env en vul de waarden in. Ontbreekt een verplichte
# waarde, dan stopt de bot bij het opstarten met een duidelijke melding.

# --- Verplicht: IMAP (Zoho) -------------------------------------------------
# Het Zoho-app-wachtwoord, NIET het inlogwachtwoord. Zelfde patroon als
# scripts/zoho-local-mail.ts in de app-repo. De user anna@ vangt via de
# catch-all ook de vh-*@-adressen op.
# LET OP: betaalde Zoho-plannen gebruiken imappro.zoho.eu, de gratis imap.zoho.eu.
# De juiste waarde staat in Zoho Mail Admin > E-mailinstellingen >
# Hulpprogramma's en configuraties > Configuraties, blok IMAP.
ZOHO_IMAP_HOST=imappro.zoho.eu
ZOHO_IMAP_USER=info@vignettehub.com
ZOHO_APP_PASSWORD=

# --- Verplicht: koppeling met de app ---------------------------------------
# Basis-URL van de VignetteHub-app. Zonder pad, zonder trailing slash.
APP_BASIS_URL=https://vignettehub.com
# Gedeeld geheim voor de bot-endpoints (Authorization: Bearer <BOT_SECRET>).
# Dit is NIET het ADMIN_SECRET; de bot heeft geen adminrechten.
BOT_SECRET=

# --- Verplicht: LLM ---------------------------------------------------------
# Anthropic API-key voor deze VM, los van het Claude-abonnement.
ANTHROPIC_API_KEY=

# --- Verplicht: escalatie ---------------------------------------------------
# Waar de bot naartoe escaleert als er een mens bij moet (meestal Sabur).
ESCALATIE_EMAIL=info@vignettehub.com

# --- Optioneel: IMAP-details ------------------------------------------------
# ZOHO_IMAP_PORT=993
# ZOHO_IMAP_SECURE=1

# --- Optioneel: schakelaars (alle drie standaard AAN) -----------------------
# Zet op 0 om te stoppen. ENABLED=lezen en verwerken, SEND=daadwerkelijk
# versturen, REFUND=daadwerkelijk terugbetalen.
# MAILBOT_ENABLED=1
# MAILBOT_SEND=1
# MAILBOT_REFUND=1

# --- Optioneel: hoeveel de bot zelf afhandelt (besluit Sabur 24-07) ---------
# Korte ontvangstbevestiging aan de klant zodra de bot naar Sabur escaleert,
# zodat het niet stil blijft. Uit bij een juridische mail en als een cap of de
# verzendrem dichtzit; dat is in de code vastgelegd, niet met deze knop.
# MAILBOT_ONTVANGSTBEVESTIGING=1
# Mag de bot zelf om een ordernummer of kenteken vragen als hij de bestelling
# niet vindt? Op 0 gaat zo'n mail meteen naar Sabur (gedrag van voor 24-07).
# MAILBOT_ZELF_DOORVRAGEN=1
# Eist de bot bewijs (DMARC- of DKIM-pass) dat het afzenderadres echt is voordat
# hij mailt naar iemand die NIET aan een bestelling te koppelen is? Zo voorkomen
# we dat iemand met een vervalst afzenderadres onze bot post laat sturen naar
# een onschuldige derde. Klanten met een gevonden bestelling merken hier niets
# van. Alleen uitzetten als blijkt dat de mailserver geen Authentication-Results
# meestuurt, want dan blokkeert de poort ook echte klanten.
# MAILBOT_EIS_AUTHENTICATIE=1

# --- Optioneel: cadans en ondertekening -------------------------------------
# POLL_SECONDEN=30
# AFZENDER_NAAM=Nina

# --- Optioneel: caps (spec sectie 9) ----------------------------------------
# CAP_ANTWOORDEN_PER_THREAD=3
# CAP_MAILS_PER_AFZENDER_24U=10
# CAP_ANTWOORDEN_PER_DAG=100
# CAP_REFUNDS_PER_DAG=10
# CAP_REFUND_EUR_PER_DAG=500

# --- Optioneel: overige knoppen ---------------------------------------------
# Vertrouwensdrempels voor de classificatie; daaronder gaat het naar mens_nodig.
# De eerste geldt voor geld, recht en wijzigingen (annuleren, betaling, factuur,
# klacht, kenteken). De tweede voor informatieve vragen (status, uitleg, bewijs
# kwijt); die mag lager, want daar wordt niets onomkeerbaars gedaan en verify.ts
# keurt elk bedrag af dat niet letterlijk in de databasefeiten staat.
# VERTROUWEN_DREMPEL=0.75
# VERTROUWEN_DREMPEL_INFO=0.45
# Modelkeuze per rol. DEFAULT voor beide = claude-opus-4-8 (besluit Sabur).
# Toegestaan: claude-opus-4-8, claude-sonnet-5, claude-haiku-4-5.
# Kostenknop: classificatie is een simpele sorteertaak; wie de kosten wil drukken
# zet classificatie op haiku (~5x goedkoper, geen merkbaar kwaliteitsverlies).
# MAILBOT_MODEL_CLASSIFICATIE=claude-opus-4-8
# MAILBOT_MODEL_OPSTELLEN=claude-opus-4-8
# Prompt-caching (standaard aan). Zet op 0 om uit te schakelen. Let op: op
# opus-4-8 cachet de API pas vanaf ~4096 tokens systeemprompt; onze prompts zijn
# kleiner, dus caching pakt pas als de kennisbank groeit.
# MAILBOT_PROMPT_CACHE=1
# HTTP-time-outs naar de app in milliseconden. Refund mag lang duren (PayPal).
# HTTP_TIMEOUT_MS=15000
# HTTP_TIMEOUT_REFUND_MS=60000
# IMAP-mapnamen.
# MAP_INBOX=INBOX
# MAP_AFGEHANDELD=Bot/Afgehandeld
# MAP_ESCALATIE=Bot/Escalatie
# MAP_FOUT=Bot/Fout
# Map waar de cap-tellers op schijf staan (overleeft een herstart).
# STATE_MAP=data
# Eigen domeinen waar de bot nooit op antwoordt.
# EIGEN_DOMEINEN=vignettehub.com,taxionspot.nl
# Debug-logging aanzetten.
# LOG_DEBUG=1
